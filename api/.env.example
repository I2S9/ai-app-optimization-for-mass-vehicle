# Copy to api/.env and fill with values from your Databricks workspace (IT).

# --- Databricks SQL warehouse ---
DATABRICKS_HOST=https://adb-xxxxxxxx.xx.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxx
DATABRICKS_TOKEN=dapixxxxxxxxxxxxxxxx

# Unity Catalog (schema must exist — see sql/001_schema.sql)
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=vehicle_mass

# default | databricks | auto  (auto = use Databricks when token set)
DATA_BACKEND=auto

# Path to exported JSON when DATA_BACKEND=default (local dev)
LOCAL_DATA_DIR=../web/public/data

# CORS — front dev server
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
