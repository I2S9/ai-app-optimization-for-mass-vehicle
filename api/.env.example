# ── Demo Supabase (recommandé) ──
DATA_BACKEND=supabase
# Supabase → Project Settings → Database → Connection string → URI
# Use "Session pooler" or "Direct" ; replace [YOUR-PASSWORD]
SUPABASE_DB_URL=postgresql://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ── Databricks (plus tard, même schéma logique) ──
# DATA_BACKEND=databricks
# DATABRICKS_HOST=https://adb-xxxx.azuredatabricks.net
# DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxx
# DATABRICKS_TOKEN=dapi...
# DATABRICKS_CATALOG=main
# DATABRICKS_SCHEMA=vehicle_mass

# ── Local sans cloud ──
# DATA_BACKEND=default

CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:8080
